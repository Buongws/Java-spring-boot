{
  "info": {
    "_postman_id": "2d6c4c39-0c7d-4f07-b65f-28f33de95b1b",
    "name": "SB Ecom API",
    "description": "Postman collection for all current API endpoints found in the project controllers. Use Sign In first to store jwtToken, then run the protected requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{jwtToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "jwtToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "categoryId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "keyword",
      "value": "phone",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign In",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"adminPass\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signin",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "signin"
              ]
            },
            "description": "Authenticate with username and password. This request stores jwtToken into collection variables."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const data = pm.response.json();",
                  "  if (data.jwtToken) {",
                  "    pm.collectionVariables.set('jwtToken', data.jwtToken);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Sign Up",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user2\",\n  \"email\": \"user2@example.com\",\n  \"password\": \"password123\",\n  \"role\": [\n    \"user\"\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "signup"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Current Username",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/username",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "username"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/user",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "user"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Sign Out",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/api/auth/signout",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "signout"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.unset('jwtToken');"
                ]
              }
            }
          ],
          "response": []
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/public/categories?pageNumber=0&pageSize=50&sortBy=categoryId&sortOrder=asc",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "public",
                "categories"
              ],
              "query": [
                {
                  "key": "pageNumber",
                  "value": "0"
                },
                {
                  "key": "pageSize",
                  "value": "50"
                },
                {
                  "key": "sortBy",
                  "value": "categoryId"
                },
                {
                  "key": "sortOrder",
                  "value": "asc"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryName\": \"Electronics\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/public/categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "public",
                "categories"
              ]
            },
            "description": "Do not send categoryId when creating a new category."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const data = pm.response.json();",
                  "  if (data.categoryId) {",
                  "    pm.collectionVariables.set('categoryId', String(data.categoryId));",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "response": []
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryName\": \"Electronics Updated\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/public/categories/{{categoryId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "public",
                "categories",
                "{{categoryId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/admin/categories/{{categoryId}}",
